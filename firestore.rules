rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidSnapshot(data) {
      return data.image is string 
          && data.image.size() > 0
          && data.timestamp is number
          && (data.moisture == null || data.moisture is number)
          && (data.score == null || data.score is number)
          && (data.analysis == null || data.analysis is string);
    }

    // Snapshots: Public read, write restricted to secret-holders (Raspberry Pi/IoT)
    match /snapshots/{snapshotId} {
      allow read: if true;
      
      // Allow creation if the secret matches the one defined in environment
      // Note: This matches the pattern in the server-side UPLOAD_SECRET
      allow create: if request.resource.data.secret == "<YOUR_UPLOAD_SECRET>" 
                   && isValidSnapshot(request.resource.data);
      
      allow update, delete: if false;
    }
  }
}
